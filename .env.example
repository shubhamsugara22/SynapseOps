APP_NAME=SynapseOps
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
APP_LOG_LEVEL=INFO

GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_API_KEY=

ADK_MODEL=gemini-2.5-flash

BIGQUERY_PROJECT=
BIGQUERY_LOCATION=US
BIGQUERY_DEFAULT_QUERY=SELECT name FROM `bigquery-public-data.usa_names.usa_1910_2013` WHERE state = 'CA' LIMIT 10

MCP_BIGQUERY_TOOLBOX_URL=
MCP_GOOGLE_MAPS_URL=
MCP_BIGQUERY_ENABLED=true
MCP_MAPS_ENABLED=false

